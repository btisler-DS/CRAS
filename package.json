{
  "name": "constitutional-runtime",
  "version": "0.1.0",
  "private": true,
  "description": "Pre-execution authorization runtime for autonomous systems",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "typecheck": "tsc --noEmit",
    "demo": "node --import tsx scripts/demo.ts",
    "test": "vitest run",
    "test:robot-worker": "python3 -m unittest robot/worker/test_cras_robot_worker.py",
    "test:vision-worker": "python3 -m unittest robot/vision/test_vision_worker.py",
    "test:browser": "playwright test",
    "test:watch": "vitest",
    "verify:robot-hat-tone": "node --import tsx scripts/verify-robot-hat-tone.ts",
    "verify:vosk-microphone": "node --import tsx scripts/verify-vosk-microphone.ts",
    "verify:physical-dispatch": "node --import tsx scripts/verify-physical-dispatch.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "postcss": "8.5.19"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
