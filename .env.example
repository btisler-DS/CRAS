# Optional server-only endpoint for the observational vision worker transport.
# The initial local value is expected to be supplied by an independently managed
# SSH forward. Tunnel lifecycle and credentials do not belong in this repository.
ROBOT_VISION_BASE_URL=http://127.0.0.1:19100

# Phase 5D-3A speech adapters are disabled by default. These values are read on
# the server only and must never be selected by browser input.
CRAS_STT_ENGINE=disabled
CRAS_TTS_ENGINE=disabled
CRAS_VOSK_MODEL_PATH=/opt/cras-runtime/models/vosk-model-small-en-us-0.15

# The simulator remains canonical and is selected by default. Physical mode is
# server-only and requires the independently supervised loopback SSH forward.
CRAS_ROBOT_ADAPTER=simulator
CRAS_PHYSICAL_WORKER_BASE_URL=http://127.0.0.1:19300
CRAS_ROBOT_SIGNING_KEY_FILE=.runtime/dispatch.key
CRAS_PHYSICAL_EVIDENCE_DB=.runtime/physical-ui-evidence.db

# Robot-local audible acknowledgments are separately disabled by default.
# When enabled, they reuse the private worker forward and signing key above.
CRAS_ROBOT_ACKNOWLEDGMENTS=disabled

# Never commit API keys, robot credentials, patient data, or evidence-store secrets.
